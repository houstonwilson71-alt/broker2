# ── BSC RPC Endpoints ──────────────────────────────────────────────────────────
BSC_RPC_WS=wss://bsc-mainnet.nodereal.io/ws/v1/YOUR_API_KEY
BSC_RPC_HTTP=https://bsc-mainnet.nodereal.io/v1/YOUR_API_KEY

# ── Wallet ─────────────────────────────────────────────────────────────────────
# NEVER commit the real private key. Set this securely.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Trading ────────────────────────────────────────────────────────────────────
LIVE_TRADING_ENABLED=false
BUY_AMOUNT_BNB=0.0005
SLIPPAGE_BPS=1500

# ── Safety Filters ─────────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=1000
MAX_AGE_SEC=300
MIN_HOLDERS=25
MAX_TOP10_PCT=35
MAX_RUG_SCORE=2

# ── Exit Strategy ──────────────────────────────────────────────────────────────
TAKE_PROFIT_1_PCT=100
TRAILING_STOP_PCT=25

# ── MEV Protection ─────────────────────────────────────────────────────────────
# Leave empty to use public mempool. Set to BloxRoute gateway URL for private relay.
BLOXROUTE_URL=

# ── Infrastructure (auto-set by docker-compose) ────────────────────────────────
DATABASE_URL=postgres://sniper:sniper@postgres:5432/sniper?sslmode=disable
REDIS_URL=redis://redis:6379/0
API_PORT=8080
