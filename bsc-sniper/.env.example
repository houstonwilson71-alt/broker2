# ── RPC ──────────────────────────────────────────────────────────────────────
BSC_RPC_WS=wss://bsc-mainnet.nodereal.io/ws/v1/<YOUR_API_KEY>
BSC_RPC_HTTP=https://bsc-mainnet.nodereal.io/v1/<YOUR_API_KEY>

# ── Wallet ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x<YOUR_PRIVATE_KEY>

# ── Trading Parameters ────────────────────────────────────────────────────────
LIVE_TRADING_ENABLED=false        # Set to true to submit real transactions
BUY_AMOUNT_BNB=0.0005             # BNB to spend per buy
SLIPPAGE_BPS=1500                 # 15% slippage tolerance

# ── Filter Thresholds ─────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=1000            # Min pool liquidity in USD
MAX_AGE_SEC=300                   # Reject pair events older than 5 minutes
MIN_HOLDERS=25                    # Minimum token holders (BSCscan)
MAX_TOP10_PCT=35                  # Max % held by top-10 wallets
MAX_RUG_SCORE=2                   # BSCScan rug pull score cap

# ── Exit Strategy ─────────────────────────────────────────────────────────────
TAKE_PROFIT_1_PCT=100             # Take-profit 1: +100% → sell 50%
TRAILING_STOP_PCT=25              # Trailing stop: -25% from ATH → sell 100%

# ── External APIs (optional) ──────────────────────────────────────────────────
BLOXROUTE_URL=                    # Leave blank to use public BSC RPC only

# ── Infrastructure (used by Docker Compose) ───────────────────────────────────
DATABASE_URL=postgres://sniper:sniper@postgres:5432/sniper?sslmode=disable
REDIS_URL=redis://redis:6379/0
API_PORT=8080
SESSION_SECRET=change_me_to_a_random_32_char_string
